# =============================================================================
#  CorridorPay — production environment
# =============================================================================
# Copy to .env.production and fill in.
# To auto-generate strong secrets:  bash scripts/init-env.sh
#
# DO NOT COMMIT .env.production. Permissions: chmod 600 .env.production
# =============================================================================

# ---------- Domains (must already point at this server) ----------
PRIMARY_DOMAIN=corridorpay.example.com
API_DOMAIN=api.corridorpay.example.com
ADMIN_DOMAIN=admin.corridorpay.example.com

# ---------- Let's Encrypt ----------
LETSENCRYPT_EMAIL=ops@example.com
# Set to 1 to use the staging CA while testing (avoids hitting prod rate-limits)
LETSENCRYPT_STAGING=0

# ---------- Backend (FastAPI) ----------
APP_ENV=production
APP_NAME=corridorpay
LOG_LEVEL=INFO

# Generate with:  openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS_FROM_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
OTP_TTL_SEC=300
FX_LOCK_TTL_SEC=300

# CORS — list of public origins allowed to call the API directly (browser).
# In nginx-proxied prod the same-origin browser flow does NOT need CORS for
# api.<domain>, but cabinet.<domain> may; keep the API/ADMIN/cabinet origins.
CORS_ORIGINS=https://corridorpay.example.com,https://admin.corridorpay.example.com

# ---------- PostgreSQL ----------
POSTGRES_DB=corridorpay
POSTGRES_USER=corridorpay
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_24_CHARS

# Async SQLAlchemy URL used by the API. Host = compose service name.
DATABASE_URL=postgresql+asyncpg://corridorpay:CHANGE_ME_RANDOM_24_CHARS@postgres:5432/corridorpay

# ---------- Frontend (Next.js) ----------
# Public API base — baked into the JS bundle at build time.
NEXT_PUBLIC_API_URL=https://api.corridorpay.example.com
# Internal SSR fetches (server → server inside the docker network)
BACKEND_URL=http://api:8000
